{% extends 'base.html.twig' %}

{% block title %}Вход{% endblock %}

{% block body %}
    <div style="max-width: 360px; margin: 80px auto; padding: 0 16px;">
        <form method="post">
            {% if error %}
                <div style="background: #fce4e4; color: #c0392b; padding: 10px 14px; border-radius: 8px; margin-bottom: 16px; font-size: 14px;">
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            {% if app.user %}
                <div style="margin-bottom: 16px; font-size: 14px;">
                    Вы вошли как {{ app.user.userIdentifier }}, <a href="{{ logout_path() }}">Выйти</a>
                </div>
            {% endif %}

            <h1 style="font-size: 24px; margin-bottom: 24px;">Remod</h1>

            <label for="username" style="display: block; font-size: 14px; margin-bottom: 4px;">Логин</label>
            <input type="text" value="{{ last_username }}" name="_username" id="username"
                   style="width: 100%; height: 44px; padding: 0 12px; border: 1px solid #ccc; border-radius: 8px; font-size: 14px; margin-bottom: 12px;"
                   autocomplete="username" required autofocus>

            <label for="password" style="display: block; font-size: 14px; margin-bottom: 4px;">Пароль</label>
            <input type="password" name="_password" id="password"
                   style="width: 100%; height: 44px; padding: 0 12px; border: 1px solid #ccc; border-radius: 8px; font-size: 14px; margin-bottom: 20px;"
                   autocomplete="current-password" required>

            <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

            <button type="submit"
                    style="width: 100%; height: 44px; background: #1C1917; color: #fff; border: none; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer;">
                Войти
            </button>
        </form>
    </div>
{% endblock %}
