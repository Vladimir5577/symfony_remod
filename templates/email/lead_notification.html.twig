<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>Новая заявка #{{ lead.id }}</title>
    <style>
        body { font-family: Arial, sans-serif; color: #333; font-size: 14px; }
        h1 { color: #0d6efd; }
        table { border-collapse: collapse; width: 100%; max-width: 560px; margin-top: 12px; }
        td { padding: 8px; border-bottom: 1px solid #eee; }
        .label { color: #888; width: 180px; vertical-align: top; }
    </style>
</head>
<body>

<h1>Новая заявка #{{ lead.id }}</h1>

<table>
    <tr>
        <td class="label">Тип заявки</td>
        <td>{{ lead.type }}</td>
    </tr>
    {% if lead.propertyType %}
    <tr>
        <td class="label">Тип объекта</td>
        <td>{{ lead.propertyType }}</td>
    </tr>
    {% endif %}
    {% if lead.area %}
    <tr>
        <td class="label">Площадь</td>
        <td>{{ lead.area }}</td>
    </tr>
    {% endif %}
    {% if lead.package %}
    <tr>
        <td class="label">Пакет</td>
        <td>{{ lead.package }}</td>
    </tr>
    {% endif %}
    {% if lead.timeframe %}
    <tr>
        <td class="label">Сроки</td>
        <td>{{ lead.timeframe }}</td>
    </tr>
    {% endif %}
    {% if lead.name %}
    <tr>
        <td class="label">Имя</td>
        <td>{{ lead.name }}</td>
    </tr>
    {% endif %}
    {% if lead.phone %}
    <tr>
        <td class="label">Телефон</td>
        <td>{{ lead.phone }}</td>
    </tr>
    {% endif %}
    {% if lead.createdAt %}
    <tr>
        <td class="label">Создана</td>
        <td>{{ lead.createdAt|date('d.m.Y H:i') }}</td>
    </tr>
    {% endif %}
</table>

</body>
</html>
